{
    "clusters": [
        {
            "cluster_name": "healthcare-ingestion-cluster",
            "description": "Shared cluster for Bronze ingestion notebooks - Claims, Eligibility, Provider, Pharmacy",
            "spark_version": "14.3.x-scala2.12",
            "node_type_id": "Standard_DS4_v2",
            "driver_node_type_id": "Standard_DS4_v2",
            "autoscale": {
                "min_workers": 2,
                "max_workers": 8
            },
            "autotermination_minutes": 60,
            "spark_conf": {
                "spark.databricks.delta.optimizeWrite.enabled": "true",
                "spark.databricks.delta.autoCompact.enabled": "true",
                "spark.sql.adaptive.enabled": "true",
                "spark.sql.adaptive.coalescePartitions.enabled": "true",
                "spark.databricks.delta.schema.autoMerge.enabled": "true"
            },
            "spark_env_vars": {
                "PYSPARK_PYTHON": "/databricks/python3/bin/python3"
            },
            "libraries": [
                { "pypi": { "package": "great-expectations==0.18.12" } },
                { "pypi": { "package": "pyyaml==6.0.1" } },
                { "pypi": { "package": "azure-keyvault-secrets==4.7.0" } }
            ],
            "init_scripts": [
                {
                    "workspace": {
                        "destination": "/HealthcarePlatform/init-scripts/install_framework.sh"
                    }
                }
            ],
            "tags": {
                "team": "data-engineering",
                "project": "healthcare-data-platform",
                "cluster_type": "ingestion",
                "hipaa": "true"
            }
        },
        {
            "cluster_name": "healthcare-ml-cluster",
            "description": "ML cluster for AI/ML workloads - readmission risk, anomaly detection, NLP",
            "spark_version": "14.3.x-gpu-ml-scala2.12",
            "node_type_id": "Standard_NC6s_v3",
            "driver_node_type_id": "Standard_DS4_v2",
            "autoscale": {
                "min_workers": 2,
                "max_workers": 6
            },
            "autotermination_minutes": 30,
            "spark_conf": {
                "spark.databricks.delta.optimizeWrite.enabled": "true",
                "spark.sql.adaptive.enabled": "true"
            },
            "libraries": [
                { "pypi": { "package": "mlflow==2.10.0" } },
                { "pypi": { "package": "xgboost==2.0.3" } },
                { "pypi": { "package": "scikit-learn==1.4.0" } },
                { "pypi": { "package": "transformers==4.37.0" } },
                { "pypi": { "package": "sentence-transformers==2.4.0" } },
                { "pypi": { "package": "fhir.resources==7.1.0" } },
                { "pypi": { "package": "hl7apy==1.3.4" } }
            ],
            "tags": {
                "team": "data-engineering",
                "project": "healthcare-data-platform",
                "cluster_type": "ml",
                "hipaa": "true"
            }
        },
        {
            "cluster_name": "healthcare-sql-warehouse",
            "description": "SQL Warehouse for Databricks SQL dashboards and ad-hoc queries",
            "cluster_type": "sql",
            "warehouse_type": "PRO",
            "size": "MEDIUM",
            "min_num_clusters": 1,
            "max_num_clusters": 3,
            "auto_stop_mins": 30,
            "enable_photon": true,
            "tags": {
                "team": "data-engineering",
                "project": "healthcare-data-platform",
                "cluster_type": "sql-warehouse"
            }
        }
    ]
}
